# Ambiente
DJANGO_ENV=production

# Seguranca basica
DJANGO_SECRET_KEY=defina-uma-chave-forte-e-unica
DJANGO_DEBUG=False
DJANGO_HEALTHZ_TOKEN=defina-um-token-aleatorio-para-healthz
DJANGO_DEBUG_EXPOSE_MEDIA=False

# Hosts e CSRF
DJANGO_ALLOWED_HOSTS=app.seudominio.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.seudominio.com

# Banco
DATABASE_URL=postgresql://usuario:senha_forte@127.0.0.1:5432/sistema_orcamentos
DJANGO_DB_CONN_MAX_AGE=60
DJANGO_DB_SSL_REQUIRE=False
SQLITE_TIMEOUT=20
DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_CACHE_BACKEND=redis
DJANGO_REDIS_CACHE_URL=redis://127.0.0.1:6379/1
DJANGO_USE_MANIFEST_STATICFILES=True

# Cookies e HTTPS
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
DJANGO_SECURE_CROSS_ORIGIN_RESOURCE_POLICY=same-origin
DJANGO_ENABLE_CSP=True

# Logs
DJANGO_LOG_LEVEL=INFO

# Uploads
DJANGO_MAX_LOGO_UPLOAD_BYTES=2097152
DJANGO_MAX_LOGO_WIDTH=2000
DJANGO_MAX_LOGO_HEIGHT=2000
DJANGO_MAX_CATALOGO_UPLOAD_BYTES=5242880
DJANGO_MAX_XLSX_PARSE_SECONDS=15
DJANGO_MAX_XLSX_NON_EMPTY_CELLS=30000

# Visitante
DJANGO_VISITANTE_RATE_LIMIT=20
DJANGO_VISITANTE_RATE_WINDOW_SECONDS=300
DJANGO_VISITANTE_TTL_HOURS=24
