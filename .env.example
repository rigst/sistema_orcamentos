# Ambiente
DJANGO_ENV=development

# Seguranca basica
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=True

# Hosts e CSRF
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# SQLite
SQLITE_TIMEOUT=20
DJANGO_USE_X_FORWARDED_PROTO=False
DJANGO_CACHE_BACKEND=locmem
DJANGO_REDIS_CACHE_URL=
DJANGO_USE_MANIFEST_STATICFILES=False

# Cookies e HTTPS
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
DJANGO_SECURE_CROSS_ORIGIN_RESOURCE_POLICY=same-origin
DJANGO_ENABLE_CSP=False

# Logs
DJANGO_LOG_LEVEL=INFO

# Uploads
DJANGO_MAX_LOGO_UPLOAD_BYTES=2097152
DJANGO_MAX_LOGO_WIDTH=2000
DJANGO_MAX_LOGO_HEIGHT=2000
DJANGO_MAX_CATALOGO_UPLOAD_BYTES=5242880
DJANGO_MAX_XLSX_PARSE_SECONDS=15
DJANGO_MAX_XLSX_NON_EMPTY_CELLS=30000

# Visitante
DJANGO_VISITANTE_RATE_LIMIT=20
DJANGO_VISITANTE_RATE_WINDOW_SECONDS=300
DJANGO_VISITANTE_TTL_HOURS=24
